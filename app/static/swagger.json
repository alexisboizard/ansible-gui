  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session",
        "description": "Session-based authentication. Login via /api/login first."
      }
    },
    "schemas": {
      "Success": {
        "type": "object",
        "properties": {
          "ok": {"type": "boolean", "example": true}
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "ok": {"type": "boolean", "example": false},
          "error": {"type": "string", "example": "Error message"}
        }
      },
      "Host": {
        "type": "object",
        "properties": {
          "id": {"type": "integer", "example": 1},
          "name": {"type": "string", "example": "web-server-01"},
          "address": {"type": "string", "example": "192.168.1.10"},
          "groups": {"type": "string", "example": "web, production"},
          "variables": {"type": "string", "example": "{\"ansible_user\": \"root\"}"},
          "os_type": {"type": "string", "enum": ["linux", "windows"], "example": "linux"},
          "created_at": {"type": "string", "format": "date-time"},
          "reachable": {"type": "boolean", "nullable": true},
          "last_ping": {"type": "string", "format": "date-time", "nullable": true},
          "ping_latency": {"type": "number", "nullable": true}
        }
      },
      "HostInput": {
        "type": "object",
        "required": ["name", "address"],
        "properties": {
          "name": {"type": "string", "example": "web-server-01"},
          "address": {"type": "string", "example": "192.168.1.10"},
          "groups": {"type": "string", "example": "web, production"},
          "variables": {"type": "object", "example": {"ansible_user": "root"}},
          "os_type": {"type": "string", "enum": ["linux", "windows"], "default": "linux"}
        }
      },
      "Folder": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "Playbook": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "content": {"type": "string"},
          "folder_id": {"type": "integer", "nullable": true},
          "folder_name": {"type": "string", "nullable": true},
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"}
        }
      },
      "PlaybookInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"},
          "content": {"type": "string"},
          "folder_id": {"type": "integer", "nullable": true}
        }
      },
      "PlaybookVersion": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "playbook_id": {"type": "integer"},
          "version_num": {"type": "integer"},
          "content": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"},
          "created_by": {"type": "string"}
        }
      },
      "Execution": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "playbook_id": {"type": "integer"},
          "playbook_name": {"type": "string"},
          "host_pattern": {"type": "string"},
          "status": {"type": "string", "enum": ["pending", "running", "success", "failed"]},
          "output": {"type": "string"},
          "started_at": {"type": "string", "format": "date-time"},
          "finished_at": {"type": "string", "format": "date-time", "nullable": true},
          "triggered_by": {"type": "string"},
          "extra_vars": {"type": "string"},
          "check_mode": {"type": "boolean"},
          "tags": {"type": "string"},
          "skip_tags": {"type": "string"}
        }
      },
      "Schedule": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "playbook_id": {"type": "integer"},
          "playbook_name": {"type": "string"},
          "host_pattern": {"type": "string"},
          "cron_expr": {"type": "string"},
          "enabled": {"type": "boolean"},
          "created_at": {"type": "string", "format": "date-time"},
          "last_run_at": {"type": "string", "format": "date-time", "nullable": true},
          "last_run_status": {"type": "string", "nullable": true},
          "next_run_at": {"type": "string", "format": "date-time", "nullable": true}
        }
      },
      "ScheduleInput": {
        "type": "object",
        "required": ["name", "playbook_id", "cron_expr"],
        "properties": {
          "name": {"type": "string"},
          "playbook_id": {"type": "integer"},
          "host_pattern": {"type": "string", "default": "all"},
          "cron_expr": {"type": "string", "example": "0 2 * * *"},
          "enabled": {"type": "boolean", "default": true}
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "username": {"type": "string"},
          "role": {"type": "string", "enum": ["admin", "readonly"]},
          "is_ldap": {"type": "boolean"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "AuditLog": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "action": {"type": "string"},
          "user": {"type": "string"},
          "target_type": {"type": "string"},
          "target_id": {"type": "integer", "nullable": true},
          "target_name": {"type": "string"},
          "details": {"type": "string"},
          "ip_address": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  }
}
