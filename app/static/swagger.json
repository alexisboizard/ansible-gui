        "security": [{"sessionAuth": []}],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {"type": "integer", "default": 1}
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {"type": "integer", "default": 50}
          },
          {
            "name": "action",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Filter by action (partial match)"
          },
          {
            "name": "user",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Filter by user (partial match)"
          }
        ],
        "responses": {
          "200": {
            "description": "Audit logs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "logs": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/AuditLog"}
                    },
                    "total": {"type": "integer"},
                    "page": {"type": "integer"},
                    "per_page": {"type": "integer"}
                  }
                }
              }
            }
          },
          "401": {"description": "Not authenticated"}
        }
      }
    }
