# Configuration SNMP générée par Ansible
# Accès restreint au poller Centreon

# Écoute sur localhost et interface réseau
agentAddress udp:161

# Accès limité au poller Centreon
rocommunity {{ snmp_community }} {{ centreon_poller_ip }}

# Informations système
sysLocation {{ snmp_location }}
sysContact {{ snmp_contact }}
sysServices 72

# Vues
view systemonly included .1.3.6.1.2.1.1
view systemonly included .1.3.6.1.2.1.25.1

# Extension pour supervision avancée
view systemonly included .1.3.6.1.4.1.2021

# Process monitoring
proc sshd
proc cron

# Disk monitoring
disk / 10%
disk /var 10%

# Load monitoring
load 12 10 5

# Extend scripts (optionnel)
# extend test /bin/echo test
