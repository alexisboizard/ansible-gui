// Configuration unattended-upgrades - générée par Ansible

Unattended-Upgrade::Allowed-Origins {
    "${distro_id}:${distro_codename}";
    "${distro_id}:${distro_codename}-security";
    "${distro_id}:${distro_codename}-updates";
};

// Liste noire de paquets
Unattended-Upgrade::Package-Blacklist {
};

// Reboot automatique
Unattended-Upgrade::Automatic-Reboot "{{ unattended_automatic_reboot | lower }}";
{% if unattended_automatic_reboot %}
Unattended-Upgrade::Automatic-Reboot-Time "{{ unattended_automatic_reboot_time }}";
{% endif %}

// Suppression des dépendances inutilisées
Unattended-Upgrade::Remove-Unused-Dependencies "true";
Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";

// Notification par mail
{% if unattended_mail %}
Unattended-Upgrade::Mail "{{ unattended_mail }}";
Unattended-Upgrade::MailReport "on-change";
{% endif %}

// Logging
Unattended-Upgrade::SyslogEnable "true";
Unattended-Upgrade::SyslogFacility "daemon";
